{
  "name": "picopics",
  "version": "2.0.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "type-check": "tsc --noEmit",
    "deploy": "./deploy.sh",
    "cf:dev": "wrangler dev",
    "cf:deploy": "wrangler deploy",
    "cf:build": "wrangler deploy --dry-run",
    "pages:build": "next-on-pages",
    "pages:deploy": "npm run pages:build && wrangler pages deploy .next",
    "vercel:deploy": "vercel --prod",
    "github:build": "next build -c next.config.github.js",
    "github:deploy": "npm run github:build && echo 'Build completed for GitHub Pages'"
  },
  "dependencies": {
    "@hookform/resolvers": "^3.3.4",
    "@radix-ui/react-dialog": "^1.0.5",
    "@radix-ui/react-dropdown-menu": "^2.0.6",
    "@radix-ui/react-progress": "^1.0.3",
    "@radix-ui/react-toast": "^1.1.5",
    "@tanstack/react-query": "^5.17.15",
    "browser-image-compression": "^2.0.2",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "framer-motion": "^11.0.24",
    "got": "^13.0.0",
    "hono": "^4.10.2",
    "lucide-react": "^0.344.0",
    "next": "^15.5.2",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-hook-form": "^7.49.3",
    "tailwind-merge": "^3.3.1",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@cloudflare/next-on-pages": "^1.13.16",
    "@cloudflare/workers-types": "^4.20241022.0",
    "@types/got": "^9.6.12",
    "@types/node": "^20.11.17",
    "@types/react": "^18.2.55",
    "@types/react-dom": "^18.2.19",
    "autoprefixer": "^10.4.17",
    "eslint": "^8.56.0",
    "eslint-config-next": "^14.1.0",
    "postcss": "^8.4.33",
    "tailwindcss": "^3.4.1",
    "tailwindcss-animate": "^1.0.7",
    "typescript": "^5.3.3",
    "wrangler": "^4.44.0"
  }
}
